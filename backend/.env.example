# Copy this file to .env and fill in your Supabase credentials.
# Find these in your Supabase project → Settings → API.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# Access tokens are verified against the project's public JWKS endpoint
# (derived from SUPABASE_URL) — no JWT secret needs to be configured.

# Service-role key — server-side ONLY, never expose to the browser.
# Required only by migrate_user.py (one-off data migration).
SUPABASE_SERVICE_KEY=your-service-role-key
